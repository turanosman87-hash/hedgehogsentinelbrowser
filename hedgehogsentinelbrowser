name: Hedgehog Sentinel EXE Olusturucu

on:
  push:
    branches: [ "main" ] # Kodunu her güncellediğinde otomatik çalışır

jobs:
  windows_derleme:
    runs-on: windows-latest # GitHub senin için Windows açar
    
    steps:
    - name: Kodlari Cek
      uses: actions/checkout@v4

    - name: Python Kur
      uses: actions/setup-python@v5
      with:
        python-version: '3.10'

    - name: Kutphaneleri Yukle
      run: |
        python -m pip install --upgrade pip
        pip install -r requirements.txt
        pip install pyinstaller

    - name: EXE Dosyasini Pişir
      run: |
        pyinstaller --onefile --windowed --name "Hedgehog_Sentinel" main.py

    - name: EXE Dosyasini Teslim Et
      uses: actions/upload-artifact@v4
      with:
        name: Hedgehog-Sentinel-Windows-Sürümü
        path: dist/Hedgehog_Sentinel.exe
